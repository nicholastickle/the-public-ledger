# Backend API URL (FastAPI server)
# Local dev: http://localhost:8000
# Production: set to your Fly.io backend URL
BACKEND_URL=http://localhost:8000

# Supabase (backend only — set in backend/.env or deployment secrets)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_URL= (migrations only, deployment secret — never in .env)
